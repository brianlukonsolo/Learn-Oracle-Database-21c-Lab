{
  "info": {
    "name": "Oracle Listener Lab - HR REST (ORDS)",
    "_postman_id": "a1b2c3d4-0000-4444-8888-oraclelablab01",
    "description": "REST APIs exposed by ORDS over the HR schema. Traffic flows: Postman -> ORDS (:8080) -> listener host (:1521) -> oracle-db (XEPDB1). Set the {{baseUrl}} collection variable if your host/port differ.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8085/ords/hr", "type": "string" }
  ],
  "item": [
    {
      "name": "List employees",
      "request": {
        "method": "GET",
        "header": [ { "key": "Accept", "value": "application/json" } ],
        "url": { "raw": "{{baseUrl}}/employees/", "host": [ "{{baseUrl}}" ], "path": [ "employees", "" ] }
      }
    },
    {
      "name": "Get employee by id (100)",
      "request": {
        "method": "GET",
        "header": [ { "key": "Accept", "value": "application/json" } ],
        "url": { "raw": "{{baseUrl}}/employees/100", "host": [ "{{baseUrl}}" ], "path": [ "employees", "100" ] }
      }
    },
    {
      "name": "Filter employees (department_id = 20)",
      "request": {
        "method": "GET",
        "header": [ { "key": "Accept", "value": "application/json" } ],
        "url": {
          "raw": "{{baseUrl}}/employees/?q={\"department_id\":20}",
          "host": [ "{{baseUrl}}" ],
          "path": [ "employees", "" ],
          "query": [ { "key": "q", "value": "{\"department_id\":20}" } ]
        }
      }
    },
    {
      "name": "Create employee (POST)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"employee_id\": 900,\n  \"first_name\": \"Ada\",\n  \"last_name\": \"Lovelace\",\n  \"email\": \"ALOVELACE\",\n  \"hire_date\": \"2024-01-15T00:00:00Z\",\n  \"job_id\": \"IT_PROG\",\n  \"salary\": 9500,\n  \"manager_id\": 101,\n  \"department_id\": 20\n}"
        },
        "url": { "raw": "{{baseUrl}}/employees/", "host": [ "{{baseUrl}}" ], "path": [ "employees", "" ] }
      }
    },
    {
      "name": "Update employee 900 (PUT upsert)",
      "request": {
        "method": "PUT",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"employee_id\": 900,\n  \"first_name\": \"Ada\",\n  \"last_name\": \"Lovelace\",\n  \"email\": \"ALOVELACE\",\n  \"hire_date\": \"2024-01-15T00:00:00Z\",\n  \"job_id\": \"IT_PROG\",\n  \"salary\": 11000,\n  \"manager_id\": 101,\n  \"department_id\": 20\n}"
        },
        "url": { "raw": "{{baseUrl}}/employees/900", "host": [ "{{baseUrl}}" ], "path": [ "employees", "900" ] }
      }
    },
    {
      "name": "Delete employee 900",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": { "raw": "{{baseUrl}}/employees/900", "host": [ "{{baseUrl}}" ], "path": [ "employees", "900" ] }
      }
    },
    {
      "name": "List departments",
      "request": {
        "method": "GET",
        "header": [ { "key": "Accept", "value": "application/json" } ],
        "url": { "raw": "{{baseUrl}}/departments/", "host": [ "{{baseUrl}}" ], "path": [ "departments", "" ] }
      }
    },
    {
      "name": "List jobs",
      "request": {
        "method": "GET",
        "header": [ { "key": "Accept", "value": "application/json" } ],
        "url": { "raw": "{{baseUrl}}/jobs/", "host": [ "{{baseUrl}}" ], "path": [ "jobs", "" ] }
      }
    },
    {
      "name": "Custom report: headcount by department",
      "request": {
        "method": "GET",
        "header": [ { "key": "Accept", "value": "application/json" } ],
        "url": { "raw": "{{baseUrl}}/reports/headcount", "host": [ "{{baseUrl}}" ], "path": [ "reports", "headcount" ] }
      }
    }
  ]
}
